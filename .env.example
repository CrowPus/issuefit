# Copy this file to .env and adjust values as needed.
# The defaults match the local Postgres started by `docker compose up -d`.

# PostgreSQL connection string used by the database package and the web app.
DATABASE_URL=postgres://issuefit:issuefit@localhost:5432/issuefit

# Worker log verbosity: fatal | error | warn | info | debug | trace.
LOG_LEVEL=info

# Weekly recommendation digest worker controls. Disabled by default for local
# development; set RUN_ON_START=true to smoke-test one digest pass.
WEEKLY_DIGEST_ENABLED=false
WEEKLY_DIGEST_INTERVAL_HOURS=168
WEEKLY_DIGEST_RUN_ON_START=false

# Email delivery for weekly digests. "log" writes delivery metadata only.
# "webhook" POSTs {from,to,toName,subject,text,html} to EMAIL_WEBHOOK_URL.
EMAIL_DELIVERY_MODE=log
EMAIL_FROM=IssueFit <noreply@localhost>
EMAIL_WEBHOOK_URL=

# Session signing secret for better-auth. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public URL of the web app (OAuth callbacks are derived from it).
BETTER_AUTH_URL=http://localhost:3000

# GitHub App OAuth credentials — see docs/development/github-app.md
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Read-only token the platform uses to fetch curated (non-user-owned) public
# repositories — see docs/development/github-service-token.md
GITHUB_SERVICE_TOKEN=

# Comma-separated GitHub usernames allowed to access /admin pages.
ADMIN_GITHUB_USERNAMES=
